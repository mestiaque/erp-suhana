    }

    public function sewingOutputs()
    {
        return $this->hasMany(SewingOutput::class, 'planning_id');
    }

    public function floorLines(){
        return Attribute::whereIn(
            'slug',
            $this->sewingLines()->pluck('line_name')
        )->get();
    }



